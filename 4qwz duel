-- --- WIDGET HELPERS ---
local function AddToggle(name, var)
    local btn = Instance.new("TextButton", Scroll)
    btn.Size = UDim2.new(1, 0, 0, 40); btn.Text = "○ " .. name; btn.BackgroundColor3 = Color3.fromRGB(25, 25, 30); btn.TextColor3 = Color3.fromRGB(200, 200, 200); btn.Font = "FredokaOne"
    Instance.new("UICorner", btn)
    btn.MouseButton1Click:Connect(function()
        Enabled[var] = not Enabled[var]
        btn.Text = Enabled[var] and "● " .. name or "○ " .. name
        btn.TextColor3 = Enabled[var] and Color3.fromRGB(0, 255, 150) or Color3.fromRGB(200, 200, 200)
    end)
end

local function AddSoon(name)
    local btn = Instance.new("TextButton", Scroll)
    btn.Size = UDim2.new(1, 0, 0, 40); btn.Text = name; btn.BackgroundColor3 = Color3.fromRGB(20, 20, 25); btn.TextColor3 = Color3.fromRGB(255, 255, 255); btn.Font = "FredokaOne"
    Instance.new("UICorner", btn)
    btn.MouseButton1Click:Connect(function() btn.Text = "Soon..." end)
end

-- Speed Widget
local SpeedFrame = Instance.new("Frame", Scroll); SpeedFrame.Size = UDim2.new(1, 0, 0, 110); SpeedFrame.BackgroundTransparency = 1
local function CreateLabel(txt, y)
    local l = Instance.new("TextLabel", SpeedFrame); l.Text = txt; l.Size = UDim2.new(1, 0, 0, 20); l.Position = UDim2.new(0, 0, 0, y); l.TextColor3 = Color3.fromRGB(255, 255, 255); l.BackgroundTransparency = 1; l.Font = "FredokaOne"
end
local function CreateBox(val, y, var)
    local b = Instance.new("TextBox", SpeedFrame); b.Size = UDim2.new(0.9, 0, 0, 25); b.Position = UDim2.new(0.05, 0, 0, y); b.Text = val; b.BackgroundColor3 = Color3.fromRGB(40, 40, 45); b.TextColor3 = Color3.fromRGB(255, 255, 255)
    Instance.new("UICorner", b)
    b.FocusLost:Connect(function() Values[var] = tonumber(b.Text) or 16 end)
end

