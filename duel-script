Stroke.Thickness = 3; Stroke.Color = Color3.fromRGB(255, 215, 0)

-- --- RESIZE BUTTON (Retrécir / Agrandir) ---
local ResizeBtn = Instance.new("TextButton")
ResizeBtn.Size = UDim2.new(0, 20, 0, 20)
ResizeBtn.Position = UDim2.new(1, -25, 1, -25)
ResizeBtn.Text = "↘"
ResizeBtn.BackgroundColor3 = Color3.fromRGB(255, 215, 0)
ResizeBtn.TextColor3 = Color3.fromRGB(0, 0, 0)
ResizeBtn.Parent = MainFrame
Instance.new("UICorner", ResizeBtn)

local resizing = false
ResizeBtn.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then resizing = true end
end)
UserInputService.InputChanged:Connect(function(input)
    if resizing and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local mousePos = UserInputService:GetMouseLocation()
        local newSizeX = mousePos.X - MainFrame.AbsolutePosition.X
        local newSizeY = (mousePos.Y - 36) - MainFrame.AbsolutePosition.Y -- Offset top bar
        MainFrame.Size = UDim2.new(0, math.max(200, newSizeX), 0, math.max(150, newSizeY))
    end
end)
UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then resizing = false end
end)

