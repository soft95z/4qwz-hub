-- Button Creator Function
local function AddOption(name, accentColor)
    local Btn = Instance.new("TextButton")
    Btn.Size = UDim2.new(0.95, 0, 0, 45)
    Btn.BackgroundColor3 = Color3.fromRGB(20, 20, 25)
    Btn.Text = "[ ]  " .. name
    Btn.TextColor3 = Color3.fromRGB(200, 200, 200)
    Btn.Font = Enum.Font.GothamMedium
    Btn.TextSize = 14
    Btn.AutoButtonColor = false
    Btn.Parent = Container

    local BtnCorner = Instance.new("UICorner")
    BtnCorner.CornerRadius = UDim.new(0, 6)
    BtnCorner.Parent = Btn

    -- Click Event
    Btn.MouseButton1Click:Connect(function()
        Btn.Text = "[X]  " .. name .. " (ACTIVE)"
        Btn.TextColor3 = accentColor
        
        -- Visual Feedback
        local tween = TweenService:Create(Btn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(40, 40, 50)})
        tween:Play()
        tween.Completed:Connect(function()
            TweenService:Create(Btn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(20, 20, 25)}):Play()
        end)
    end)
end

-- Layout Elements
