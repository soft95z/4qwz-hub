-- --- TOGGLE CREATOR ---
local function AddToggle(name, callback)
    local state = false
    local b = Instance.new("TextButton")
    b.Size = UDim2.new(0.95, 0, 0, 40); b.Text = "○ " .. name
    b.BackgroundColor3 = Color3.fromRGB(40,35,55); b.TextColor3 = Color3.fromRGB(200,200,200)
    b.Font = Enum.Font.FredokaOne; b.Parent = Scroll; Instance.new("UICorner", b)
    b.MouseButton1Click:Connect(function()
        state = not state
        b.Text = state and "● " .. name or "○ " .. name
        b.TextColor3 = state and Color3.fromRGB(0, 255, 150) or Color3.fromRGB(200, 200, 200)
        callback(state)
    end)
end

