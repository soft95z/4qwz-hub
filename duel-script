-- --- WIDGET CREATOR ---
local function CreateWidget(name, sizeX, sizeY)
    local W = Instance.new("Frame")
    W.Size = UDim2.new(0, sizeX, 0, sizeY); W.Position = UDim2.new(0.1, 0, 0.1, 0)
    W.BackgroundColor3 = Color3.fromRGB(15, 15, 20); W.Visible = false; W.Active = true; W.Parent = ScreenGui
    Instance.new("UICorner", W); local S = Instance.new("UIStroke", W); S.Thickness = 2; applyRainbow(S)
    makeDraggable(W)
    
    local T = Instance.new("TextLabel")
    T.Size = UDim2.new(1, 0, 0, 30); T.Text = name; T.Font = "FredokaOne"; T.BackgroundTransparency = 1; T.Parent = W
    applyRainbow(T)
    return W
end

