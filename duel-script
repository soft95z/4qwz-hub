-- --- WIDGET CREATOR ---
local function CreateWidget(name, color, callback)
    local W = Instance.new("Frame")
    W.Size = UDim2.new(0, 150, 0, 80); W.Position = UDim2.new(0.1, 0, 0.4, 0)
    W.BackgroundColor3 = Color3.fromRGB(25, 25, 35); W.Visible = false; W.Parent = ScreenGui
    Instance.new("UICorner", W); Instance.new("UIStroke", W).Color = color
    makeDraggable(W)
    
    local T = Instance.new("TextLabel")
    T.Size = UDim2.new(1, 0, 0, 30); T.Text = name; T.TextColor3 = Color3.fromRGB(255,255,255)
    T.Font = "FredokaOne"; T.BackgroundTransparency = 1; T.Parent = W
    
    local ActionBtn = Instance.new("TextButton")
    ActionBtn.Size = UDim2.new(0.8, 0, 0, 30); ActionBtn.Position = UDim2.new(0.1, 0, 0.5, 0)
    ActionBtn.Text = "OFF"; ActionBtn.BackgroundColor3 = Color3.fromRGB(45, 45, 60)
    ActionBtn.TextColor3 = Color3.fromRGB(255,255,255); ActionBtn.Font = "FredokaOne"
    ActionBtn.Parent = W; Instance.new("UICorner", ActionBtn)
    
    local active = false
    ActionBtn.MouseButton1Click:Connect(function()
        active = not active
        ActionBtn.Text = active and "ON" or "OFF"
        ActionBtn.TextColor3 = active and color or Color3.fromRGB(255, 255, 255)
        if callback then callback(active) end
    end)
    
    return W
end

