-- --- SPEED FLOATING MENU ---
local SpeedFrame = Instance.new("Frame")
SpeedFrame.Size = UDim2.new(0, 150, 0, 120)
SpeedFrame.Position = UDim2.new(0.8, 0, 0.5, 0)
SpeedFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 30)
SpeedFrame.Visible = false
SpeedFrame.Parent = ScreenGui
Instance.new("UICorner", SpeedFrame); Instance.new("UIStroke", SpeedFrame).Color = Color3.fromRGB(0, 255, 255)
makeDraggable(SpeedFrame)

local function AddSpeedBtn(text, speedVal)
    local b = Instance.new("TextButton")
    b.Size = UDim2.new(0.9, 0, 0, 40)
    b.Text = text; b.Font = Enum.Font.FredokaOne; b.TextColor3 = Color3.fromRGB(255,255,255)
    b.BackgroundColor3 = Color3.fromRGB(40,40,60)
    b.Parent = SpeedFrame
    Instance.new("UICorner", b)
    b.MouseButton1Click:Connect(function()
        local char = Player.Character or Player.CharacterAdded:Wait()
        char.Humanoid.WalkSpeed = speedVal
        b.TextColor3 = Color3.fromRGB(0, 255, 150)
        wait(0.2); b.TextColor3 = Color3.fromRGB(255, 255, 255)
    end)
end
Instance.new("UIListLayout", SpeedFrame).HorizontalAlignment = Enum.HorizontalAlignment.Center
AddSpeedBtn("Speed Regular", 30)
AddSpeedBtn("Speed Stealing", 100)

-- --- MAIN SCROLL ---
