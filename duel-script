-- Draggable Logic
local function makeDraggable(frame)
    local dragging, dragInput, dragStart, startPos
    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
        end
    end)
    frame.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
end
makeDraggable(MainFrame)

-- Buttons with Fun Font
local function AddOption(name)
    local isEnabled = false
    local B = Instance.new("TextButton")
    B.Size = UDim2.new(0.95, 0, 0, 45)
    B.BackgroundColor3 = Color3.fromRGB(40, 30, 60)
    B.Text = "OFF ⮕ " .. name
    B.TextColor3 = Color3.fromRGB(200, 200, 200)
    B.Font = Enum.Font.FredokaOne -- Police Fun & Arrondie
    B.TextSize = 16
    B.Parent = Scroll
    
    Instance.new("UICorner", B).CornerRadius = UDim.new(0, 10)

    B.MouseButton1Click:Connect(function()
        isEnabled = not isEnabled
        if isEnabled then
            B.Text = "ON ⮕ " .. name
            B.TextColor3 = Color3.fromRGB(255, 215, 0)
            B.BackgroundColor3 = Color3.fromRGB(60, 40, 90)
        else
            B.Text = "OFF ⮕ " .. name
            B.TextColor3 = Color3.fromRGB(200, 200, 200)
            B.BackgroundColor3 = Color3.fromRGB(40, 30, 60)
        end
        
        -- Bounce animation
        B:TweenSize(UDim2.new(0.9, 0, 0, 40), "Out", "Quad", 0.1, true)
        wait(0.1)
        B:TweenSize(UDim2.new(0.95, 0, 0, 45), "Out", "Quad", 0.1, true)
    end)
end

