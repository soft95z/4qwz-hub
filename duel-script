    4QWZ DUEL BEST SCRIPT - CUSTOMIZABLE EDITION
    Features: Draggable, Resizable UI, Floating Speed Menu
--]]

local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local CoreGui = game:GetService("CoreGui")
local Player = game:GetService("Players").LocalPlayer

-- Nettoyage
if CoreGui:FindFirstChild("4qwz_Advanced_Hub") then
    CoreGui:FindFirstChild("4qwz_Advanced_Hub"):Destroy()
end

local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "4qwz_Advanced_Hub"
ScreenGui.Parent = CoreGui
ScreenGui.ResetOnSpawn = false

-- --- SYSTÈME DE DRAG (DÉPLACEMENT) ---
local function makeDraggable(frame)
    local dragging, dragInput, dragStart, startPos
    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true; dragStart = input.Position; startPos = frame.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = false end
    end)
end

-- --- MAIN FRAME ---
local MainFrame = Instance.new("Frame")
