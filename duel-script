-- --- WIDGET CREATOR (For Floating Buttons) ---
local function CreateWidget(name, color)
    local W = Instance.new("Frame")
    W.Size = UDim2.new(0, 120, 0, 45)
    W.Position = UDim2.new(0.1, 0, 0.5, 0)
    W.BackgroundColor3 = Color3.fromRGB(25, 25, 35)
    W.Visible = false; W.Active = true; W.Parent = ScreenGui
    Instance.new("UICorner", W); local s = Instance.new("UIStroke", W); s.Color = color; s.Thickness = 2
    makeDraggable(W)
    
    local B = Instance.new("TextButton")
    B.Size = UDim2.new(1, 0, 1, 0); B.BackgroundTransparency = 1
    B.Text = name .. ": OFF"; B.TextColor3 = Color3.fromRGB(255, 255, 255)
    B.Font = Enum.Font.FredokaOne; B.Parent = W
    
    local active = false
    B.MouseButton1Click:Connect(function()
        active = not active
        B.Text = active and name .. ": ON" or name .. ": OFF"
        B.TextColor3 = active and color or Color3.fromRGB(255, 255, 255)
    end)
    
    return W
end

