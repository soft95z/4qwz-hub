-- --- VARIABLES & LOOPS ---
_G.InfJ = false; _G.Spin = false; _G.StickyAim = false; _G.Neon = false; _G.Spam = false; _G.AntiRag = false

-- Sticky Aimbot Logic
AimBtn.MouseButton1Click:Connect(function()
    _G.StickyAim = not _G.StickyAim
    AimBtn.Text = _G.StickyAim and "STICKY AIM: ON" or "STICKY AIM: OFF"
    AimBtn.BackgroundColor3 = _G.StickyAim and Color3.fromRGB(255, 50, 50) or Color3.fromRGB(60, 60, 60)
end)

RunService.Heartbeat:Connect(function()
    if _G.StickyAim and Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") then
        local target = nil; local dist = 25
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= Player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character.Humanoid.Health > 0 then
                local d = (p.Character.HumanoidRootPart.Position - Player.Character.HumanoidRootPart.Position).Magnitude
                if d < dist then dist = d; target = p.Character end
            end
        end
        if target then
            Player.Character.HumanoidRootPart.CFrame = target.HumanoidRootPart.CFrame * CFrame.new(0, 0, 3)
            local tool = Player.Character:FindFirstChildOfClass("Tool") or Player.Backpack:FindFirstChildOfClass("Tool")
            if tool then 
                if tool.Parent ~= Player.Character then Player.Character.Humanoid:EquipTool(tool) end
                tool:Activate() 
            end
        end
    end
    -- Neon Force
    if _G.Neon then Lighting.Ambient = Color3.fromRGB(255, 0, 255); Lighting.Brightness = 3 end
    -- Spin Bot
    if _G.Spin and Player.Character then Player.Character.HumanoidRootPart.CFrame *= CFrame.Angles(0, math.rad(25), 0) end
    -- Anti Ragdoll
    if _G.AntiRag and Player.Character then Player.Character.Humanoid:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false) end
end)

-- Infinite Jump (Safe)
UserInputService.JumpRequest:Connect(function()
    if _G.InfJ and Player.Character then Player.Character.Humanoid:ChangeState(Enum.HumanoidStateType.Jumping) end
end)

