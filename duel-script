-- --- LOGIC ---
_G.InfJ = false; _G.Spin = false; _G.Aim = false; _G.Neon = false; _G.Spam = false; _G.AntiRag = false; _G.CustomSpeed = 16

AimStateBtn.MouseButton1Click:Connect(function() _G.Aim = not _G.Aim; AimStateBtn.Text = _G.Aim and "ON" or "OFF" end)

RunService.Heartbeat:Connect(function()
    if Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") then
        local hrp = Player.Character.HumanoidRootPart
        local hum = Player.Character.Humanoid
        
        -- Speed Force
        hum.WalkSpeed = _G.CustomSpeed
        
        -- Spin Bot Fix (Marche en marchant)
        if _G.Spin then hrp.CFrame = hrp.CFrame * CFrame.Angles(0, math.rad(25), 0) end
        
        -- Aimbot Sticky
        if _G.Aim then
            local target = nil; local dist = 30
            for _, p in pairs(Players:GetPlayers()) do
                if p ~= Player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character.Humanoid.Health > 0 then
                    local d = (p.Character.HumanoidRootPart.Position - hrp.Position).Magnitude
                    if d < dist then dist = d; target = p.Character end
                end
            end
            if target then
                hrp.CFrame = target.HumanoidRootPart.CFrame * CFrame.new(0, 0, 2)
                local tool = Player.Character:FindFirstChildOfClass("Tool") or Player.Backpack:FindFirstChildOfClass("Tool")
                if tool then 
                    if tool.Parent ~= Player.Character then hum:EquipTool(tool) end
                    tool:Activate() 
                end
            end
        end

        -- Spam Bat
        if _G.Spam and not _G.Aim then
            local tool = Player.Character:FindFirstChildOfClass("Tool")
            if tool then tool:Activate() end
        end
    end
    
    if _G.Neon then 
        Lighting.Ambient = Color3.fromRGB(40, 0, 80)
        Lighting.OutdoorAmbient = Color3.fromRGB(20, 0, 40)
        Lighting.Brightness = 2
    end
end)

