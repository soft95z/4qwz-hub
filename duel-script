local function AddToggle(name, callback)
    local s = false
    local b = Instance.new("TextButton")
    b.Size = UDim2.new(0.95, 0, 0, 40); b.Text = "○ " .. name
    b.BackgroundColor3 = Color3.fromRGB(35, 30, 50); b.TextColor3 = Color3.fromRGB(200,200,200)
    b.Font = "FredokaOne"; b.Parent = Scroll; Instance.new("UICorner", b)
    b.MouseButton1Click:Connect(function()
        s = not s; callback(s)
        b.Text = s and "● " .. name or "○ " .. name
        b.TextColor3 = s and Color3.fromRGB(0, 255, 150) or Color3.fromRGB(200, 200, 200)
    end)
end

