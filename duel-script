Scroll.Size = UDim2.new(0.9, 0, 0.7, 0)
Scroll.Position = UDim2.new(0.05, 0, 0.2, 0)
Scroll.BackgroundTransparency = 1; Scroll.Parent = MainFrame
Instance.new("UIListLayout", Scroll).HorizontalAlignment = Enum.HorizontalAlignment.Center

local function AddToggle(name, callback)
    local state = false
    local b = Instance.new("TextButton")
    b.Size = UDim2.new(0.95, 0, 0, 40); b.Text = "○ " .. name
    b.BackgroundColor3 = Color3.fromRGB(40,30,60); b.TextColor3 = Color3.fromRGB(200,200,200)
    b.Font = Enum.Font.FredokaOne; b.Parent = Scroll
    Instance.new("UICorner", b)
    b.MouseButton1Click:Connect(function()
        state = not state
        b.Text = state and "● " .. name or "○ " .. name
        b.TextColor3 = state and Color3.fromRGB(255, 215, 0) or Color3.fromRGB(200, 200, 200)
        callback(state)
    end)
end

AddToggle("Speed Boost Menu", function(s) SpeedFrame.Visible = s end)
AddToggle("Neon Sky", function(s) game:GetService("Lighting").Brightness = s and 4 or 1 end)
AddToggle("Infinite Jump", function(s) _G.inf = s end)

game:GetService("UserInputService").JumpRequest:Connect(function()
    if _G.inf then Player.Character.Humanoid:ChangeState("Jumping") end
end)

makeDraggable(MainFrame)
MainFrame.Size = UDim2.new(0, 0, 0, 0)
TweenService:Create(MainFrame, TweenInfo.new(1, Enum.EasingStyle.Elastic), {Size = UDim2.new(0, 420, 0, 400)}):Play()
