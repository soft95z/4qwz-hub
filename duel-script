-- --- LOGIQUE BAT SPAM & AIMBOT ---
task.spawn(function()
    while task.wait(0.05) do
        local char = Player.Character
        if not char then continue end
        
        -- Fonction pour équiper automatiquement et frapper
        local function autoEquipAndSwing()
            local tool = char:FindFirstChildOfClass("Tool")
            if not tool then
                -- Cherche la batte dans l'inventaire si elle n'est pas en main
                tool = Player.Backpack:FindFirstChildOfClass("Tool")
                if tool and char:FindFirstChild("Humanoid") then
                    char.Humanoid:EquipTool(tool)
                end
            end
            if tool then tool:Activate() end
        end

        local hrp = char:FindFirstChild("HumanoidRootPart")
        
        if _G.BatAimbot and hrp then
            -- Logique de l'Aimbot
            local closest = nil
            local minDist = 40 -- Portée maximale de détection
            
            for _, p in pairs(Players:GetPlayers()) do
                if p ~= Player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character:FindFirstChild("Humanoid") and p.Character.Humanoid.Health > 0 then
                    local dist = (p.Character.HumanoidRootPart.Position - hrp.Position).Magnitude
                    if dist < minDist then
                        minDist = dist
                        closest = p
                    end
                end
            end
            
            if closest then
                -- Tourne le joueur vers la cible
                hrp.CFrame = CFrame.new(hrp.Position, Vector3.new(closest.Character.HumanoidRootPart.Position.X, hrp.Position.Y, closest.Character.HumanoidRootPart.Position.Z))
                -- Frappe automatiquement
                autoEquipAndSwing()
            end
            
        elseif _G.BatSpam then
            -- Spam basique sans Aimbot
            autoEquipAndSwing()
        end
    end
end)

